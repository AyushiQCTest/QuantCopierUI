# Firebase Configuration
# For DB_Service_FireBaseAdmin.py (Firebase Admin SDK)
# Set FIREBASE_CREDENTIALS to the JSON string of your Firebase service account key
# OR set FIREBASE_CREDENTIALS_PATH to the path of your service account JSON file
FIREBASE_CREDENTIALS='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...","client_id":"..."}'

# Firebase Database URL
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app/

# For DB_Service.py (Legacy Firebase REST API)
# Firebase REST API authentication token
FIREBASE_AUTH_TOKEN=your_firebase_rest_api_token

# Instructions for obtaining these values:
# 1. FIREBASE_CREDENTIALS: Download from Firebase Console > Project Settings > Service Accounts > Generate new private key
# 2. FIREBASE_DATABASE_URL: Find in Firebase Console > Realtime Database > Data tab (URL at top)
# 3. FIREBASE_AUTH_TOKEN: Find in Firebase Console > Project Settings > Database Secrets (legacy, for REST API)

# Releases bucket (use full Firebase bucket id, e.g. project.firebasestorage.app)
# FIREBASE_STORAGE_BUCKET
# Path to service account JSON for the storage project (preferred over inline JSON)
# FIREBASE_SERVICE_ACCOUNT_KEY=firebase_service_account_key.json
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=firebase_service_account_key.json

# IMPORTANT: Never commit actual credentials to version control
# Store credentials in environment variables or use a secure secrets manager

# --- Dev-mode VERSION lookup ---
# When running the sidecar as a PyInstaller frozen exe during development the
# VERSION file is not found inside the temp _MEI directory. Set this to the
# repo root (the directory that contains the VERSION file) so get_ui_version()
# can read it correctly.
# QUANTCOPIER_SOURCE_DIR=C:\Users\YourUser\QuantTraderTools\QuantCopierUI
