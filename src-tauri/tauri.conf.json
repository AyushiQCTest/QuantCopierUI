{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QuantCopierMT5",
  "version": "0.1.0",
  "identifier": "com.quantcopier.dev",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run next-start",
    "beforeBuildCommand": "npm run next-build"
  },
  "app": {
    "windows": [
      {
        "title": "QuantCopier",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/QuantCopierMT5TelegramSetup.ico",
        "installMode": "currentUser",
        "template": "nsis/installer.nsi"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/QuantCopierAPI"
    ]
  }
}