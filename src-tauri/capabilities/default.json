{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/QuantCopierAPI",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/QuantCopierTelegram",
          "sidecar": true
        }
      ]
    },
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://**/"
        },
        {
          "url": "https://**/"
        }
      ]
    },
    "shell:default",
    "http:default"
  ]
}